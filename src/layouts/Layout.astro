---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Track US Visa & Immigration Processing Times." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Open Graph / Social Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://usvisatracker.example.com/" />
		
		<!-- Google Analytics Placeholder -->
		<!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
		<script>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());
		  gtag('config', 'G-XXXXXXXXXX');
		</script> -->
	</head>
	<body class="bg-[#fafafa] text-neutral-900 font-sans antialiased min-h-screen flex flex-col selection:bg-neutral-200 selection:text-neutral-900">
		<header class="bg-white/80 backdrop-blur-md border-b border-neutral-200 sticky top-0 z-10 transition-colors">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center h-16">
					<div class="flex-shrink-0 flex items-center">
						<a href="/" class="text-xl font-bold tracking-tighter text-neutral-900 hover:text-neutral-600 transition-colors">US Visa Tracker</a>
					</div>
					<nav class="hidden md:flex space-x-6 items-center">
						<a href="/uscis-processing-times" class="text-neutral-500 hover:text-neutral-900 px-2 py-2 rounded-md text-sm font-medium transition-colors">Processing Times</a>
						<a href="/green-card/visa-bulletin" class="text-neutral-500 hover:text-neutral-900 px-2 py-2 rounded-md text-sm font-medium transition-colors">Visa Bulletin</a>
						<a href="/uscis-processing-times/historic-trends" class="text-neutral-500 hover:text-neutral-900 px-2 py-2 rounded-md text-sm font-medium transition-colors">Historic Trends</a>
						<span class="text-neutral-300">|</span>
						<a href="/about-us" class="text-neutral-400 hover:text-neutral-900 px-2 py-2 rounded-md text-sm font-medium transition-colors">About</a>
						<a href="/contact-us" class="text-neutral-400 hover:text-neutral-900 px-2 py-2 rounded-md text-sm font-medium transition-colors">Contact</a>
					</nav>
				</div>
			</div>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<footer class="bg-[#fafafa] mt-12 py-10 border-t border-neutral-200">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center text-sm">
				<div class="mb-4 md:mb-0 text-center md:text-left">
					<p class="mb-2 font-medium text-neutral-800">Not affiliated with USCIS, DHS, or the US State Department.</p>
					<p class="text-neutral-500 max-w-md">Data is sourced from public government publications and updated monthly. For official information, always refer to uscis.gov and travel.state.gov.</p>
				</div>
				<div class="flex flex-wrap justify-center md:justify-end gap-6 text-neutral-500">
					<a href="/about-us" class="hover:text-neutral-900 transition-colors">About Us</a>
					<a href="/contact-us" class="hover:text-neutral-900 transition-colors">Contact Us</a>
					<a href="/privacy-policy" class="hover:text-neutral-900 transition-colors">Privacy Policy</a>
					<a href="/terms-and-conditions" class="hover:text-neutral-900 transition-colors">Terms & Conditions</a>
				</div>
			</div>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 pt-8 border-t border-neutral-200 text-center text-neutral-400 text-xs">
				&copy; {new Date().getFullYear()} US Visa Tracker. All Rights Reserved.
			</div>
		</footer>
	</body>
</html>
