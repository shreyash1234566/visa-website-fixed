---
interface Props {
  pageUrl?: string;
  pageIdentifier?: string;
  title?: string;
}
const { pageUrl, pageIdentifier, title } = Astro.props;
const url = pageUrl || Astro.url.href;
const identifier = pageIdentifier || Astro.url.pathname;
---

<div class="bg-white border border-neutral-200 rounded-2xl p-6 mt-8">
  <h3 class="text-base font-bold text-neutral-900 mb-4">Community Discussion</h3>
  <div id="disqus_thread"></div>
</div>

<script define:vars={{ url, identifier, title }}>
  // Ensure the config is globally available
  window.disqus_config = function () {
    this.page.url = url;
    this.page.identifier = identifier;
    if (title) this.page.title = title;
  };

  window.DISQUS_SHORTNAME = 'us-visa-tracker';

  function loadDisqus() {
    var el = document.getElementById('disqus_thread');
    if (!el) return;

    if (window.DISQUS) {
      // Disqus is already loaded on a previous page view. 
      // We must tell it to reset and re-bind to the new #disqus_thread div.
      window.DISQUS.reset({
        reload: true,
        config: window.disqus_config
      });
      return;
    }

    if (window.__disqusLoading) return;
    window.__disqusLoading = true;

    var d = document, s = d.createElement('script');
    s.src = 'https://' + window.DISQUS_SHORTNAME + '.disqus.com/embed.js';
    s.setAttribute('data-timestamp', +new Date());
    (d.head || d.body).appendChild(s);
  }

  function initDisqus() {
    var el = document.getElementById('disqus_thread');
    if (!el) return;
    
    // Lazy-load Disqus when the thread div scrolls into view
    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        loadDisqus();
        observer.disconnect();
      }
    }, { rootMargin: '200px' });
    
    observer.observe(el);
  }

  // Run immediately for standard page loads
  initDisqus();

  // Run on subsequent loads if Astro View Transitions are ever enabled
  document.addEventListener('astro:page-load', initDisqus);
</script>

<noscript>
  <p class="text-sm text-neutral-500">Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript" class="underline">comments powered by Disqus</a>.</p>
</noscript>
