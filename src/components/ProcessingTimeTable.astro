---
interface CaseTypeEntry {
  caseType: string;
  minMonths: number;
  maxMonths: number;
  serviceRequestDate: string | null;
  history: { period: string; min: number; max: number }[];
}

interface Props {
  centerName: string;
  centerCode: string;
  cases: CaseTypeEntry[];
}

const { centerName, centerCode, cases } = Astro.props;

function trend(c: CaseTypeEntry) {
  if (c.history.length < 2) return null;
  const prev = c.history[c.history.length - 2];
  const diff = c.maxMonths - prev.max;
  if (Math.abs(diff) < 0.15) return { label: 'Stable', cls: 'bg-neutral-100 text-neutral-700' };
  if (diff < 0) return { label: 'Improving', cls: 'bg-green-100 text-green-800' };
  return { label: 'Slower', cls: 'bg-amber-100 text-amber-800' };
}

function formatDate(d: string | null) {
  if (!d) return '—';
  try {
    return new Date(d + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
  } catch {
    return d;
  }
}
---

<div class="bg-white rounded-2xl shadow-sm border border-neutral-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between bg-neutral-50/60">
    <h3 class="font-bold text-neutral-900">{centerName}</h3>
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-neutral-900 text-white">{centerCode}</span>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-neutral-200 text-sm">
      <thead class="bg-neutral-50">
        <tr>
          <th class="px-6 py-3 text-left font-semibold text-neutral-500 uppercase tracking-wider text-xs">Case Type</th>
          <th class="px-6 py-3 text-left font-semibold text-neutral-500 uppercase tracking-wider text-xs">Processing Range</th>
          <th class="px-6 py-3 text-left font-semibold text-neutral-500 uppercase tracking-wider text-xs">Service Request Date</th>
          <th class="px-6 py-3 text-left font-semibold text-neutral-500 uppercase tracking-wider text-xs">Trend</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-neutral-100">
        {cases.map((c) => {
          const t = trend(c);
          return (
            <tr class="hover:bg-neutral-50/50 transition-colors">
              <td class="px-6 py-4 text-neutral-900 font-medium max-w-xs">{c.caseType}</td>
              <td class="px-6 py-4 whitespace-nowrap text-neutral-700">{c.minMonths} – {c.maxMonths} months</td>
              <td class="px-6 py-4 whitespace-nowrap text-neutral-500">{formatDate(c.serviceRequestDate)}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                {t && <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${t.cls}`}>{t.label}</span>}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  {cases[0]?.serviceRequestDate && (
    <div class="px-6 py-3 bg-blue-50 border-t border-blue-100 text-xs text-blue-900">
      If your case was filed on or before the service request date for your category and you're still waiting outside the posted range, you can submit an <strong>e-Request</strong> to USCIS.
    </div>
  )}
</div>
