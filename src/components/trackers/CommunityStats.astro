---
interface ChartFieldMeta {
  key: string;
  label: string;
}

interface Props {
  instanceId: string; // unique per page, e.g. "h1b"
  rows: Record<string, any>[];
  chartFields: ChartFieldMeta[];
}

const { instanceId, rows, chartFields } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
  {chartFields.map((f) => (
    <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-5">
      <h3 class="text-sm font-bold text-neutral-900 mb-3">{f.label}</h3>
      <div class="relative h-48">
        <canvas class="tracker-donut" data-instance={instanceId} data-field={f.key}></canvas>
      </div>
    </div>
  ))}
</div>

<script type="application/json" data-stats-rows={instanceId} set:html={JSON.stringify(rows)} />
<script define:vars={{ instanceId, chartFields }}>
  // exposed so the live-data fetch script (in the page) can push fresh rows in
  window[`__stats_${instanceId}`] = { update: null };
</script>

<script>
  import Chart from 'chart.js/auto';

  const PALETTE = ['#171717', '#10b981', '#f59e0b', '#3b82f6', '#ef4444', '#8b5cf6', '#ec4899', '#14b8a6'];

  function aggregate(rows: any[], field: string) {
    const counts = new Map<string, number>();
    for (const row of rows) {
      let val = row[field];
      if (val === true) val = 'Yes';
      else if (val === false) val = 'No';
      else if (val === null || val === undefined || val === '') val = 'Unknown';
      counts.set(val, (counts.get(val) || 0) + 1);
    }
    return [...counts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
  }

  function renderInstance(instanceId: string) {
    const dataEl = document.querySelector(`script[data-stats-rows="${instanceId}"]`);
    if (!dataEl) return;
    const rows = JSON.parse(dataEl.textContent || '[]');

    const charts: Record<string, Chart> = {};

    document.querySelectorAll<HTMLCanvasElement>(`canvas.tracker-donut[data-instance="${instanceId}"]`).forEach((canvas) => {
      const field = canvas.getAttribute('data-field');
      if (!field) return;
      const agg = aggregate(rows, field);
      const chart = new Chart(canvas, {
        type: 'doughnut',
        data: {
          labels: agg.map(([k]) => k),
          datasets: [{ data: agg.map(([, v]) => v), backgroundColor: PALETTE, borderWidth: 0 }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } } },
        },
      });
      charts[field] = chart;
    });

    (window as any)[`__stats_${instanceId}`].update = (newRows: any[]) => {
      Object.entries(charts).forEach(([field, chart]) => {
        const agg = aggregate(newRows, field);
        chart.data.labels = agg.map(([k]) => k);
        chart.data.datasets[0].data = agg.map(([, v]) => v);
        chart.update();
      });
    };
  }

  document.querySelectorAll('script[data-stats-rows]').forEach((el) => {
    const id = el.getAttribute('data-stats-rows');
    if (id) renderInstance(id);
  });
</script>
