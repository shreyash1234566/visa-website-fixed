---
interface ColumnMeta {
  key: string;
  label: string;
}

interface Props {
  instanceId: string;
  rows: Record<string, any>[];
  columns: ColumnMeta[];
  pageSize?: number;
}

const { instanceId, rows, columns, pageSize = 25 } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-sm border border-neutral-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-neutral-200 text-sm">
      <thead class="bg-neutral-50">
        <tr>
          {columns.map((c) => (
            <th class="px-4 py-3 text-left font-semibold text-neutral-500 uppercase tracking-wider text-xs cursor-pointer select-none hover:text-neutral-900" data-sort-col={c.key} data-instance={instanceId}>
              {c.label} <span class="sort-arrow opacity-30">↕</span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-neutral-100" data-table-body={instanceId}></tbody>
    </table>
  </div>
  <div class="flex items-center justify-between px-4 py-3 border-t border-neutral-100 text-xs text-neutral-500">
    <span data-page-info={instanceId}></span>
    <div class="flex gap-2">
      <button data-prev={instanceId} class="px-3 py-1.5 rounded-lg border border-neutral-200 hover:bg-neutral-50 disabled:opacity-40 disabled:cursor-not-allowed font-medium">Prev</button>
      <button data-next={instanceId} class="px-3 py-1.5 rounded-lg border border-neutral-200 hover:bg-neutral-50 disabled:opacity-40 disabled:cursor-not-allowed font-medium">Next</button>
    </div>
  </div>
</div>

<script type="application/json" data-table-rows={instanceId} set:html={JSON.stringify(rows)} />
<script type="application/json" data-table-cols={instanceId} set:html={JSON.stringify(columns)} />
<script define:vars={{ instanceId, pageSize }}>
  window[`__table_${instanceId}`] = { update: null };
  window[`__pageSize_${instanceId}`] = pageSize;
</script>

<script>
  function fmtVal(v: any) {
    if (v === true) return '✅';
    if (v === false) return '—';
    if (v === null || v === undefined || v === '') return '—';
    return String(v);
  }

  function initTable(instanceId: string) {
    const rowsEl = document.querySelector(`script[data-table-rows="${instanceId}"]`);
    const colsEl = document.querySelector(`script[data-table-cols="${instanceId}"]`);
    const body = document.querySelector(`[data-table-body="${instanceId}"]`) as HTMLElement;
    const pageInfo = document.querySelector(`[data-page-info="${instanceId}"]`) as HTMLElement;
    const prevBtn = document.querySelector(`[data-prev="${instanceId}"]`) as HTMLButtonElement;
    const nextBtn = document.querySelector(`[data-next="${instanceId}"]`) as HTMLButtonElement;
    if (!rowsEl || !colsEl || !body) return;

    const pageSize: number = (window as any)[`__pageSize_${instanceId}`] || 25;
    let rows: any[] = JSON.parse(rowsEl.textContent || '[]');
    const cols: { key: string; label: string }[] = JSON.parse(colsEl.textContent || '[]');
    let page = 0;
    let sortKey: string | null = null;
    let sortDir = 1;

    function render() {
      let sorted = [...rows];
      if (sortKey) {
        sorted.sort((a, b) => {
          const av = a[sortKey as string] ?? '';
          const bv = b[sortKey as string] ?? '';
          return av > bv ? sortDir : av < bv ? -sortDir : 0;
        });
      }
      const totalPages = Math.max(1, Math.ceil(sorted.length / pageSize));
      page = Math.min(page, totalPages - 1);
      const slice = sorted.slice(page * pageSize, (page + 1) * pageSize);

      body.innerHTML = slice.map((row) => `
        <tr class="hover:bg-neutral-50/50 transition-colors">
          ${cols.map((c) => `<td class="px-4 py-3 whitespace-nowrap text-neutral-700">${fmtVal(row[c.key])}</td>`).join('')}
        </tr>
      `).join('') || `<tr><td colspan="${cols.length}" class="px-4 py-6 text-center text-neutral-400">No cases yet — be the first to submit one.</td></tr>`;

      if (pageInfo) pageInfo.textContent = `${sorted.length} case${sorted.length === 1 ? '' : 's'} · page ${page + 1} of ${totalPages}`;
      if (prevBtn) prevBtn.disabled = page === 0;
      if (nextBtn) nextBtn.disabled = page >= totalPages - 1;
    }

    document.querySelectorAll(`th[data-sort-col][data-instance="${instanceId}"]`).forEach((th) => {
      th.addEventListener('click', () => {
        const key = th.getAttribute('data-sort-col');
        if (sortKey === key) sortDir *= -1; else { sortKey = key; sortDir = 1; }
        page = 0;
        render();
      });
    });

    prevBtn?.addEventListener('click', () => { page = Math.max(0, page - 1); render(); });
    nextBtn?.addEventListener('click', () => { page += 1; render(); });

    (window as any)[`__table_${instanceId}`].update = (newRows: any[]) => {
      rows = newRows;
      page = 0;
      render();
    };

    render();
  }

  document.querySelectorAll('script[data-table-rows]').forEach((el) => {
    const id = el.getAttribute('data-table-rows');
    if (id) initTable(id);
  });
</script>
