---
interface Props {
  history: { period: string; waitTimeB1B2: number | null }[];
  title?: string;
}
const { history, title = "12-Month Wait Time Trend" } = Astro.props;

const chartData = {
  labels: history.map((h) => new Date(h.period + '-01T00:00:00Z').toLocaleDateString('en-US', { month: 'short', year: '2-digit', timeZone: 'UTC' })),
  values: history.map((h) => h.waitTimeB1B2),
};
---

<div class="bg-white p-6 rounded-2xl shadow-sm border border-neutral-200">
  <h3 class="text-base font-bold text-neutral-900 mb-4">{title}</h3>
  <div class="relative h-56 w-full">
    <canvas class="wt-chart" data-chart={JSON.stringify(chartData)}></canvas>
  </div>
</div>

<script>
  import Chart from 'chart.js/auto';
  function init() {
    document.querySelectorAll<HTMLCanvasElement>('canvas.wt-chart').forEach((canvas) => {
      if ((canvas as any)._init) return;
      (canvas as any)._init = true;
      const raw = canvas.getAttribute('data-chart');
      if (!raw) return;
      const d = JSON.parse(raw);
      new Chart(canvas, {
        type: 'line',
        data: {
          labels: d.labels,
          datasets: [{
            label: 'Wait time (days)',
            data: d.values,
            borderColor: '#171717',
            backgroundColor: 'rgba(23,23,23,0.06)',
            fill: true,
            tension: 0.3,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true, title: { display: true, text: 'Days' } } },
        },
      });
    });
  }
  init();
</script>
