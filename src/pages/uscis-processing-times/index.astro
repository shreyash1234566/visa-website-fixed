---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const forms = await getCollection('processingTimes');

const CATEGORY_LABELS: Record<string, string> = {
  'work-visas': 'Work Visas',
  'green-card': 'Green Card / Employment-Based',
  student: 'Student Visas',
  dependent: 'Dependent Visas',
  citizenship: 'Citizenship',
  other: 'Other',
};

const grouped = new Map<string, typeof forms>();
for (const f of forms) {
  const list = grouped.get(f.data.category) || [];
  list.push(f);
  grouped.set(f.data.category, list);
}
const categoryOrder = ['work-visas', 'green-card', 'dependent', 'student', 'citizenship', 'other'];

const lastUpdated = forms.length
  ? forms.map((f) => f.data.lastUpdated).sort().reverse()[0]
  : null;
---

<Layout title="USCIS Processing Times — All Forms [2026]" description="Browse official USCIS processing times for H-1B, L-1, O-1, I-140, I-485, N-400 and more, broken down by service center with historical trend charts.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'USCIS Processing Times' }]} />

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 border-b border-neutral-200 pb-6 mb-12">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-2">USCIS Processing Times</h1>
        <p class="text-lg text-neutral-500">Official processing time ranges for every major visa and green card form, by service center.</p>
      </div>
      {lastUpdated && (
        <span class="inline-flex items-center gap-2 text-xs font-medium text-neutral-500 bg-neutral-100 px-3 py-1.5 rounded-full self-start">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Last updated {new Date(lastUpdated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
      )}
    </div>

    {categoryOrder.map((cat) => {
      const list = grouped.get(cat);
      if (!list || !list.length) return null;
      return (
        <div class="mb-14">
          <h2 class="text-xl font-bold tracking-tight text-neutral-900 mb-5">{CATEGORY_LABELS[cat] || cat}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {list.sort((a, b) => a.data.visaLabel.localeCompare(b.data.visaLabel)).map((f) => {
              const allCases = f.data.servicecenters.flatMap((sc) => sc.cases);
              const minOfMin = Math.min(...allCases.map((c) => c.minMonths));
              const maxOfMax = Math.max(...allCases.map((c) => c.maxMonths));
              return (
                <a href={`/uscis-processing-times/${f.data.visaSlug}`} class="block bg-white border border-neutral-200 rounded-2xl p-6 hover:border-neutral-900 hover:shadow-md transition-all group">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-neutral-900 group-hover:underline">{f.data.visaLabel}</h3>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-neutral-100 text-neutral-700 shrink-0">{f.data.formType}</span>
                  </div>
                  <p class="text-sm text-neutral-500 mb-5 min-h-[20px]">{f.data.formName}</p>
                  <div class="flex items-baseline gap-2 border-t border-neutral-100 pt-4">
                    <span class="text-2xl font-black tracking-tight text-neutral-900">{minOfMin}–{maxOfMax}</span>
                    <span class="text-sm text-neutral-500">months</span>
                  </div>
                  <div class="mt-4 flex items-center text-sm font-medium text-neutral-400 group-hover:text-neutral-900 transition-colors">
                    View details &amp; trends <span aria-hidden="true" class="ml-1">&rarr;</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}

    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-5">
      <a href="/uscis-stats/historic-trends" class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6 hover:border-neutral-900 transition-all">
        <h3 class="font-bold text-neutral-900 mb-1">USCIS Quarterly Stats &amp; Historic Trends</h3>
        <p class="text-sm text-neutral-500">Receipt and completion volumes by fiscal quarter, straight from USCIS reports.</p>
      </a>
      <a href="/green-card/visa-bulletin" class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6 hover:border-neutral-900 transition-all">
        <h3 class="font-bold text-neutral-900 mb-1">Visa Bulletin &amp; Priority Dates</h3>
        <p class="text-sm text-neutral-500">Track green card priority date movement by country and category.</p>
      </a>
    </div>
  </div>
</Layout>
