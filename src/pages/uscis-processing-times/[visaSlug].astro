---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ProcessingTimeTable from '../../components/ProcessingTimeTable.astro';
import ProcessingTimeChart from '../../components/ProcessingTimeChart.astro';
import ReceiptDatePredictor from '../../components/ReceiptDatePredictor.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import DisqusComments from '../../components/DisqusComments.astro';
import EmailCapture from '../../components/EmailCapture.astro';

export async function getStaticPaths() {
  const forms = await getCollection('processingTimes');
  return forms.map((entry) => ({
    params: { visaSlug: entry.data.visaSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const f = entry.data;

const allForms = await getCollection('processingTimes');
const relatedEntries = f.relatedPages
  .map((href: string) => allForms.find((x) => `/uscis-processing-times/${x.data.visaSlug}` === href))
  .filter(Boolean);

const allCases = f.servicecenters.flatMap((sc) => sc.cases);
const minOfMin = Math.min(...allCases.map((c) => c.minMonths));
const maxOfMax = Math.max(...allCases.map((c) => c.maxMonths));

// Noindex pages still on seed data to protect YMYL accuracy trust signal
const shouldNoIndex = f.dataSource === 'seed';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'USCIS Processing Times', href: '/uscis-processing-times' },
  { label: f.visaLabel, href: `/uscis-processing-times/${f.visaSlug}` },
];

// JSON-LD: WebApplication (for the predictor tool) + Dataset
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: `${f.visaLabel} Processing Time Predictor`,
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    name: `USCIS Processing Times — ${f.visaLabel} (${f.formType})`,
    description: f.seoDesc,
    dateModified: f.lastUpdated,
    creator: { "@type": "Organization", name: "U.S. Citizenship and Immigration Services" },
    url: f.sourceUrl,
  },
];
---

<Layout title={f.seoTitle} description={f.seoDesc} breadcrumbs={breadcrumbs} noindex={shouldNoIndex}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'USCIS Processing Times', href: '/uscis-processing-times' },
      { label: f.visaLabel },
    ]} />

    <div class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-neutral-900 text-white text-xs font-semibold tracking-wide uppercase">{f.formType}</span>
        <span class="inline-flex items-center gap-2 text-xs font-medium text-neutral-500 bg-neutral-100 px-3 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Updated {new Date(f.lastUpdated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
        {f.dataSource === 'seed' && (
          <span class="inline-flex items-center text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200 px-3 py-1.5 rounded-full" title="This build is using placeholder seed data. Run `npm run data:fetch` on a network with access to uscis.gov to pull live figures.">
            Sample data — run data:fetch for live figures
          </span>
        )}
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-4">{f.seoTitle}</h1>
      <p class="text-xl text-neutral-500">{f.formName}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6 sm:col-span-1">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Overall Range</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{minOfMin}–{maxOfMax}<span class="text-base font-medium text-neutral-500"> mo</span></p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6 sm:col-span-1">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Service Centers</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{f.servicecenters.length}</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6 sm:col-span-1">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Case Types Tracked</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{allCases.length}</p>
      </div>
    </div>

    <!-- Predictor Tool -->
    <div class="mb-12">
      <ReceiptDatePredictor servicecenters={f.servicecenters} />
    </div>

    <!-- Per service center tables + trend chart -->
    <div class="space-y-10 mb-12">
      {f.servicecenters.map((sc) => (
        <div>
          <ProcessingTimeTable centerName={sc.name} centerCode={sc.code} cases={sc.cases} />
          {sc.cases[0]?.history?.length > 1 && (
            <div class="mt-4">
              <ProcessingTimeChart
                title={`${sc.name} — "${sc.cases[0].caseType}" trend`}
                history={sc.cases[0].history.map((h: any) => ({ date: h.period + '-01', rangeLowMonths: h.min, rangeHighMonths: h.max }))}
              />
            </div>
          )}
        </div>
      ))}
    </div>

    {relatedEntries.length > 0 && (
      <div class="mb-12">
        <h2 class="text-lg font-bold text-neutral-900 mb-4">Related Pages</h2>
        <div class="flex flex-wrap gap-3">
          {relatedEntries.map((r: any) => (
            <a href={`/uscis-processing-times/${r.data.visaSlug}`} class="px-4 py-2 rounded-full bg-white border border-neutral-200 text-sm font-medium text-neutral-700 hover:border-neutral-900 hover:text-neutral-900 transition-colors">
              {r.data.visaLabel} &rarr;
            </a>
          ))}
          <a href="/uscis-trackers" class="px-4 py-2 rounded-full bg-emerald-50 border border-emerald-200 text-sm font-medium text-emerald-800 hover:border-emerald-400 transition-colors">
            {f.visaLabel} Community Tracker &rarr;
          </a>
        </div>
      </div>
    )}

    <div class="prose prose-neutral max-w-none text-neutral-600 bg-neutral-50 p-8 rounded-2xl border border-neutral-200 mb-4">
      <p class="text-sm leading-relaxed">{f.seoText}</p>
      <p class="text-xs mt-4 mb-0">
        Source: <a href={f.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-neutral-900 font-medium hover:underline">USCIS Processing Times</a>
      </p>
    </div>

    <FAQAccordion faqs={f.faqs} title={`${f.visaLabel} FAQs`} />
    <div class="mt-8">
      <EmailCapture alertType="newsletter" label="Get Processing Time Alerts" sublabel="We'll notify you when USCIS updates processing times for this form." />
    </div>
    <DisqusComments pageIdentifier={`processing-${f.visaSlug}`} title={`${f.visaLabel} Processing Time Discussion`} />
  </div>
</Layout>
