---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { TRACKERS } from '../lib/trackers';
---

<Layout title="My Dashboard — US Visa Tracker" description="Manage the cases you've submitted to the community trackers.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Dashboard' }]} />

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900 mb-1">My Dashboard</h1>
        <p id="dash-email" class="text-neutral-500 text-sm"></p>
      </div>
      <button id="signout-btn" class="hidden px-4 py-2 rounded-xl border border-neutral-200 text-sm font-medium text-neutral-700 hover:bg-neutral-50 transition-colors">Sign Out</button>
    </div>

    <div id="signed-out-notice" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800">
      You need to <a href="/login" class="font-semibold underline">sign in</a> to view your dashboard.
    </div>

    <div id="loading-notice" class="text-sm text-neutral-400">Loading…</div>

    <div id="dash-content" class="hidden space-y-8"></div>
  </div>
</Layout>

<script define:vars={{ trackers: Object.values(TRACKERS).map((t) => ({ slug: t.slug, table: t.table, label: t.label, urlPath: t.urlPath, fields: t.fields.slice(0, 4) })) }}>
  window.__dashboardTrackers = trackers;
</script>

<script>
  import { getSession, signOut } from '../lib/auth';

  const signedOutNotice = document.getElementById('signed-out-notice')!;
  const loadingNotice = document.getElementById('loading-notice')!;
  const content = document.getElementById('dash-content')!;
  const emailEl = document.getElementById('dash-email')!;
  const signoutBtn = document.getElementById('signout-btn')!;

  async function fetchJson(url: string) {
    const res = await fetch(url, { credentials: 'same-origin' });
    if (!res.ok) return [];
    return res.json();
  }

  async function init() {
    const user = await getSession();
    loadingNotice.classList.add('hidden');

    if (!user) {
      signedOutNotice.classList.remove('hidden');
      return;
    }
    emailEl.textContent = user.email;
    signoutBtn.classList.remove('hidden');

    const trackers = (window as any).__dashboardTrackers || [];
    let html = '';
    for (const t of trackers) {
      const rows = await fetchJson(`/api/trackers/${t.table}/mine`);
      html += `
        <div class="bg-white border border-neutral-200 rounded-2xl overflow-hidden">
          <div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between bg-neutral-50/60">
            <h2 class="font-bold text-neutral-900">${t.label}</h2>
            <a href="${t.urlPath}" class="text-xs font-medium text-neutral-500 hover:text-neutral-900">View tracker &rarr;</a>
          </div>
          ${rows.length === 0
            ? `<p class="px-6 py-5 text-sm text-neutral-400">You haven't submitted a case here yet.</p>`
            : `<div class="divide-y divide-neutral-100">${rows.map((r: any) => `
                <div class="px-6 py-4 flex items-center justify-between text-sm">
                  <div class="text-neutral-600">
                    ${t.fields.map((f: any) => `<span class="mr-4"><span class="text-neutral-400">${f.label}:</span> ${r[f.key] ?? '—'}</span>`).join('')}
                  </div>
                  <button data-delete="${t.table}:${r.id}" class="text-red-500 hover:underline text-xs font-medium">Delete</button>
                </div>
              `).join('')}</div>`
          }
        </div>`;
    }
    content.innerHTML = html;
    content.classList.remove('hidden');

    content.querySelectorAll('[data-delete]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const [table, id] = (btn.getAttribute('data-delete') || '').split(':');
        if (!table || !id) return;
        if (!confirm('Delete this case?')) return;
        await fetch(`/api/trackers/${table}/${id}`, { method: 'DELETE', credentials: 'same-origin' });
        init();
      });
    });
  }

  signoutBtn?.addEventListener('click', async () => {
    await signOut();
    window.location.href = '/';
  });

  init();
</script>
