---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Create an Account — US Visa Tracker" description="Create an account to submit and manage your community tracker cases.">
  <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Register' }]} />

    <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900 mb-2">Create an Account</h1>
    <p class="text-neutral-500 mb-8">Free, no spam — just enough to attribute your case submissions to you.</p>

    <div id="not-configured" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-5 text-sm text-amber-800 mb-6">
      Registration isn't connected to a database yet on this deployment. See the README for how to connect Prisma Postgres.
    </div>

    <form id="register-form" class="space-y-4 bg-white border border-neutral-200 rounded-2xl p-6 shadow-sm">
      <div>
        <label for="email" class="block text-xs font-semibold text-neutral-700 mb-1.5 uppercase tracking-wide">Email</label>
        <input id="email" type="email" required class="w-full px-3 py-2.5 rounded-lg border border-neutral-200 bg-neutral-50 text-sm focus:ring-2 focus:ring-neutral-900" />
      </div>
      <div>
        <label for="password" class="block text-xs font-semibold text-neutral-700 mb-1.5 uppercase tracking-wide">Password</label>
        <input id="password" type="password" required minlength="8" class="w-full px-3 py-2.5 rounded-lg border border-neutral-200 bg-neutral-50 text-sm focus:ring-2 focus:ring-neutral-900" />
        <p class="text-xs text-neutral-400 mt-1">At least 8 characters.</p>
      </div>
      <button type="submit" class="w-full bg-neutral-900 text-white font-semibold py-3 rounded-xl hover:bg-neutral-700 transition-colors">Create Account</button>
      <p id="register-msg" class="text-sm hidden"></p>
    </form>

    <p class="text-center text-sm text-neutral-500 mt-6">
      Already have an account? <a href="/login" class="font-medium text-neutral-900 hover:underline">Sign in</a>
    </p>
  </div>
</Layout>

<script>
  import { signUpWithEmail } from '../lib/auth';

  const notConfigured = document.getElementById('not-configured');
  const form = document.getElementById('register-form') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('register-msg') as HTMLElement;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    msg.classList.remove('hidden');
    msg.className = 'text-sm text-neutral-500';
    msg.textContent = 'Creating account…';
    try {
      await signUpWithEmail(email, password);
      window.location.href = '/dashboard';
    } catch (err: any) {
      const isConfigError = /DATABASE_URL|not set|fetch failed|Unexpected token/i.test(err.message || '');
      if (isConfigError) {
        notConfigured?.classList.remove('hidden');
        msg.classList.add('hidden');
      } else {
        msg.className = 'text-sm text-red-600';
        msg.textContent = err.message || 'Could not create account.';
      }
    }
  });
</script>
