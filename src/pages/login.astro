---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Sign In — US Visa Tracker" description="Sign in to submit and manage your community tracker cases.">
  <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Sign In' }]} />

    <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900 mb-2">Sign In</h1>
    <p class="text-neutral-500 mb-8">Sign in to submit and manage your tracker cases.</p>

    <div id="not-configured" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-5 text-sm text-amber-800 mb-6">
      Sign-in isn't connected to a database yet on this deployment. See the README for how to connect Prisma Postgres.
    </div>

    <form id="login-form" class="space-y-4 bg-white border border-neutral-200 rounded-2xl p-6 shadow-sm">
      <div>
        <label for="email" class="block text-xs font-semibold text-neutral-700 mb-1.5 uppercase tracking-wide">Email</label>
        <input id="email" type="email" required class="w-full px-3 py-2.5 rounded-lg border border-neutral-200 bg-neutral-50 text-sm focus:ring-2 focus:ring-neutral-900" />
      </div>
      <div>
        <label for="password" class="block text-xs font-semibold text-neutral-700 mb-1.5 uppercase tracking-wide">Password</label>
        <input id="password" type="password" required class="w-full px-3 py-2.5 rounded-lg border border-neutral-200 bg-neutral-50 text-sm focus:ring-2 focus:ring-neutral-900" />
      </div>
      <button type="submit" class="w-full bg-neutral-900 text-white font-semibold py-3 rounded-xl hover:bg-neutral-700 transition-colors">Sign In</button>
      <p id="login-msg" class="text-sm hidden"></p>
    </form>

    <p class="text-center text-sm text-neutral-500 mt-6">
      Don't have an account? <a href="/register" class="font-medium text-neutral-900 hover:underline">Register</a>
    </p>
  </div>
</Layout>

<script>
  import { signInWithEmail } from '../lib/auth';

  const notConfigured = document.getElementById('not-configured');
  const form = document.getElementById('login-form') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('login-msg') as HTMLElement;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    msg.classList.remove('hidden');
    msg.className = 'text-sm text-neutral-500';
    msg.textContent = 'Signing in…';
    try {
      await signInWithEmail(email, password);
      window.location.href = '/dashboard';
    } catch (err: any) {
      const isConfigError = /DATABASE_URL|not set|fetch failed|Unexpected token/i.test(err.message || '');
      if (isConfigError) {
        notConfigured?.classList.remove('hidden');
        msg.classList.add('hidden');
      } else {
        msg.className = 'text-sm text-red-600';
        msg.textContent = err.message || 'Could not sign in.';
      }
    }
  });
</script>
