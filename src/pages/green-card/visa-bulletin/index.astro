---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { BULLETIN_COUNTRIES } from '../../../../scripts/lib/formsConfig.mjs';

const visaBulletinData = await getCollection('visaBulletin');

const months = [...new Set(visaBulletinData.map((d) => d.data.month))].sort().reverse();
const currentMonth = months[0] || 'No data';
const currentData = visaBulletinData.filter((d) => d.data.month === currentMonth);

const formattedMonth = currentMonth !== 'No data'
  ? new Date(`${currentMonth}-01T00:00:00Z`).toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' })
  : currentMonth;

const ebData = currentData.filter((d) => d.data.category.startsWith('EB'));

function bySlug(name: string) {
  const found = BULLETIN_COUNTRIES.find((c) => c.name === name)?.slug;
  if (found) return found;
  if (name.toLowerCase().includes('india')) return 'india';
  if (name.toLowerCase().includes('china')) return 'china';
  return 'rest-of-world';
}
---

<Layout title="Visa Bulletin Tracker — Priority Dates by Country [2026]" description="Track the latest Visa Bulletin movement, Final Action Dates, and Dates for Filing for Employment-based green cards by country.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Visa Bulletin' }]} />

    <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-4">Visa Bulletin Tracker</h1>
    <p class="text-lg text-neutral-500 mb-8">Track priority dates and movement for Employment-Based green cards, by country of birth.</p>

    <!-- Priority Date Estimator Banner -->
    <a href="/green-card/priority-date-calculator" class="block bg-emerald-50 border border-emerald-200 rounded-xl p-6 mb-10 hover:bg-emerald-100 hover:shadow-sm transition-all group">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center shrink-0 shadow-sm">
          <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-emerald-900 mb-1">Priority Date Estimator</h3>
          <p class="text-sm text-emerald-700">Calculate an estimated wait time based on recent bulletin movement. <span class="font-medium group-hover:underline">Try it now &rarr;</span></p>
        </div>
      </div>
    </a>

    <!-- Country grid -->
    <h2 class="text-xl font-bold tracking-tight text-neutral-900 mb-5">Browse by Country</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-14">
      {BULLETIN_COUNTRIES.map((c) => {
        const rows = ebData.filter((d) => d.data.country === c.name);
        const eb2 = rows.find((r) => r.data.category === 'EB-2');
        return (
          <a href={`/green-card/visa-bulletin/${c.slug}`} class="block bg-white border border-neutral-200 rounded-2xl p-6 hover:border-neutral-900 hover:shadow-md transition-all group">
            <h3 class="text-lg font-bold text-neutral-900 group-hover:underline mb-3">{c.name}</h3>
            {eb2 && (
              <div class="flex items-center justify-between text-sm">
                <span class="text-neutral-500">EB-2 Final Action Date</span>
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${eb2.data.finalActionDate === 'C' ? 'bg-green-100 text-green-800' : 'bg-neutral-100 text-neutral-800'}`}>
                  {eb2.data.finalActionDate === 'C' ? 'Current' : eb2.data.finalActionDate}
                </span>
              </div>
            )}
            <div class="mt-4 flex items-center text-sm font-medium text-neutral-400 group-hover:text-neutral-900 transition-colors">
              View all categories &amp; trends <span aria-hidden="true" class="ml-1">&rarr;</span>
            </div>
          </a>
        );
      })}
    </div>

    <h2 class="text-2xl font-bold tracking-tight text-neutral-900 mb-6">{formattedMonth} — All Countries</h2>
    <div class="bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden mb-12">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-neutral-200 text-sm">
          <thead class="bg-neutral-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left font-semibold text-neutral-900 uppercase tracking-wider">Category</th>
              <th scope="col" class="px-6 py-3 text-left font-semibold text-neutral-900 uppercase tracking-wider">Country</th>
              <th scope="col" class="px-6 py-3 text-left font-semibold text-neutral-900 uppercase tracking-wider">Final Action Date</th>
              <th scope="col" class="px-6 py-3 text-left font-semibold text-neutral-900 uppercase tracking-wider">Date for Filing</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-neutral-200">
            {ebData.sort((a, b) => a.data.category.localeCompare(b.data.category) || a.data.country.localeCompare(b.data.country)).map((entry) => {
              const { category, country, finalActionDate, dateForFiling } = entry.data;
              return (
                <tr class="hover:bg-neutral-50/50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-neutral-900">{category}</td>
                  <td class="px-6 py-4 whitespace-nowrap text-neutral-500">
                    <a href={`/green-card/visa-bulletin/${bySlug(country)}`} class="hover:underline hover:text-neutral-900">{country}</a>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${finalActionDate === 'C' ? 'bg-green-100 text-green-800' : 'bg-neutral-100 text-neutral-800'}`}>
                      {finalActionDate === 'C' ? 'Current' : finalActionDate}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${dateForFiling === 'C' ? 'bg-green-100 text-green-800' : 'bg-neutral-100 text-neutral-800'}`}>
                      {dateForFiling === 'C' ? 'Current' : dateForFiling}
                    </span>
                  </td>
                </tr>
              );
            })}
            {ebData.length === 0 && (
              <tr>
                <td colspan="4" class="px-6 py-4 text-center text-sm text-neutral-500">No data available for this month.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
