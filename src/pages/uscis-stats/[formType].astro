---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProcessingTimeChart from '../../components/ProcessingTimeChart.astro'; // We'll reuse this chart component but tweak its props/usage, or I should maybe just render a placeholder or build a StatsChart

export async function getStaticPaths() {
  const stats = await getCollection('uscisQuarterlyStats');
  
  // Group by formType
  const forms = [...new Set(stats.map(s => s.data.formType))];
  
  return forms.map(formType => {
    // Filter stats for this form and sort chronologically
    const history = stats
      .filter(s => s.data.formType === formType)
      .sort((a, b) => {
        if (a.data.fiscalYear !== b.data.fiscalYear) return a.data.fiscalYear - b.data.fiscalYear;
        return a.data.quarter - b.data.quarter;
      });
      
    return {
      params: { formType: formType.toLowerCase() },
      props: { 
        formType, 
        formName: history[0].data.formName,
        history,
        latest: history[history.length - 1]
      },
    };
  });
}

const { formType, formName, history, latest } = Astro.props;

// Prepare data for the chart
// We'll chart Pending cases over time
const chartHistory = history.map(h => ({
  date: `FY${h.data.fiscalYear} Q${h.data.quarter}`,
  rangeLowMonths: h.data.receipts || 0, // Hack: reusing the chart props for now to show Receipts vs Completions
  rangeHighMonths: h.data.completions || 0
}));

---

<Layout title={`${formType} Quarterly Stats & Trends`} description={`Check the latest USCIS official statistics for ${formName} including receipts, completions, and pending case volumes.`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Breadcrumbs -->
    <nav class="flex text-sm text-neutral-500 mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2">
        <li><a href="/uscis-stats" class="hover:text-neutral-900 transition-colors">USCIS Quarterly Stats</a></li>
        <li><span class="px-1 text-neutral-300">/</span></li>
        <li><span class="text-neutral-900 font-medium">{formType}</span></li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-neutral-100 text-neutral-800 text-xs font-semibold tracking-wide uppercase mb-6">
        Latest Data: FY{latest.data.fiscalYear} Q{latest.data.quarter}
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-4">{formType} Statistics</h1>
      <p class="text-xl text-neutral-500">{formName}</p>
    </div>

    <!-- Latest Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Pending</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{latest.data.pending?.toLocaleString() || 'N/A'}</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Receipts</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{latest.data.receipts?.toLocaleString() || 'N/A'}</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Completions</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{latest.data.completions?.toLocaleString() || 'N/A'}</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">RFE Rate</p>
        <p class="text-3xl font-black tracking-tighter text-neutral-900">{latest.data.rfeRate ? `${latest.data.rfeRate}%` : 'N/A'}</p>
      </div>
    </div>

    <!-- Chart Section -->
    <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-6 md:p-8 mb-12">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Historical Volume Trend</h2>
      </div>
      <div class="h-80 w-full relative">
        <ProcessingTimeChart 
          history={chartHistory} 
          title="Receipts vs Completions"
        />
      </div>
      <div class="mt-4 flex gap-4 text-xs font-medium text-neutral-500 justify-center">
        <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-[#a3a3a3]"></span> Receipts</div>
        <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-[#171717]"></span> Completions</div>
      </div>
    </div>

    <div class="prose prose-neutral max-w-none text-neutral-600 bg-neutral-50 p-8 rounded-2xl border border-neutral-200">
      <h3 class="text-lg font-bold text-neutral-900 mt-0">Data Source & Methodology</h3>
      <p class="text-sm">
        The statistics above are derived directly from the official USCIS "All USCIS Application and Petition Form Types" quarterly reports. 
        <strong>Receipts</strong> indicate new applications filed during the quarter. 
        <strong>Completions</strong> include approvals, denials, and rejections. 
        <strong>Pending</strong> is the total backlog at the end of the quarter.
      </p>
      <p class="text-sm mb-0">
        Original Source: <a href={latest.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-neutral-900 font-medium hover:underline">USCIS Immigration and Citizenship Data</a><br/>
        Last updated: {new Date(latest.data.lastUpdated).toLocaleDateString()}
      </p>
    </div>

  </div>
</Layout>
