---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const stats = await getCollection('uscisQuarterlyStats');

// Group the latest stats by formType (finding the max fiscalYear and quarter per formType)
const latestStatsMap = new Map();

stats.forEach(entry => {
  const current = latestStatsMap.get(entry.data.formType);
  if (!current || 
      entry.data.fiscalYear > current.data.fiscalYear || 
      (entry.data.fiscalYear === current.data.fiscalYear && entry.data.quarter > current.data.quarter)) {
    latestStatsMap.set(entry.data.formType, entry);
  }
});

const latestStats = Array.from(latestStatsMap.values()).sort((a, b) => a.data.formType.localeCompare(b.data.formType));
---

<Layout title="USCIS Quarterly Stats Hub" description="Track the latest official USCIS quarterly processing statistics, including receipts, completions, pending cases, and RFE rates for H-1B, Green Cards, and Citizenship.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex justify-between items-end border-b border-neutral-200 pb-6 mb-12">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-2">USCIS Quarterly Statistics</h1>
        <p class="text-lg text-neutral-500">Official data on case volumes and RFE rates across major form types.</p>
      </div>
      <a href="/uscis-stats/historic-trends" class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-neutral-900 bg-white border border-neutral-200 px-4 py-2 rounded-lg hover:border-neutral-900 hover:shadow-sm transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
        View Historic Trends
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestStats.map(entry => {
        const { formType, formName, fiscalYear, quarter, pending, rfeRate } = entry.data;
        return (
          <a href={`/uscis-stats/${formType.toLowerCase()}`} class="block bg-white border border-neutral-200 rounded-2xl p-6 md:p-8 hover:border-neutral-900 hover:shadow-md transition-all group">
            <div class="flex justify-between items-start mb-4">
              <h2 class="text-2xl font-bold tracking-tight text-neutral-900">{formType}</h2>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-neutral-100 text-neutral-800">FY{fiscalYear} Q{quarter}</span>
            </div>
            <p class="text-sm text-neutral-500 mb-6 min-h-[40px]">{formName}</p>
            
            <div class="grid grid-cols-2 gap-4 border-t border-neutral-100 pt-6">
              <div>
                <p class="text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Pending Cases</p>
                <p class="text-xl font-bold text-neutral-900">{pending?.toLocaleString() || 'N/A'}</p>
              </div>
              <div>
                <p class="text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">RFE Rate</p>
                <p class="text-xl font-bold text-neutral-900">{rfeRate ? `${rfeRate}%` : 'N/A'}</p>
              </div>
            </div>
            
            <div class="mt-6 flex items-center text-sm font-medium text-neutral-400 group-hover:text-neutral-900 transition-colors">
              View full report <span aria-hidden="true" class="ml-1">&rarr;</span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-12 sm:hidden text-center">
      <a href="/uscis-stats/historic-trends" class="inline-flex items-center gap-2 text-sm font-medium text-neutral-900 bg-white border border-neutral-200 px-6 py-3 rounded-xl hover:border-neutral-900 hover:shadow-sm transition-all w-full justify-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
        View Historic Trends
      </a>
    </div>

    <div class="mt-16 bg-neutral-50 rounded-2xl p-6 md:p-8 border border-neutral-200">
      <h3 class="text-lg font-bold tracking-tight text-neutral-900 mb-2">About this data</h3>
      <p class="text-sm text-neutral-600 leading-relaxed max-w-3xl">
        This page tracks the official quarterly statistics published by U.S. Citizenship and Immigration Services (USCIS). 
        Unlike the processing times estimates, which are forward-looking projections, these quarterly stats reflect the actual number of applications received, approved, denied, and pending during the given fiscal quarter. 
        Data is sourced directly from <a href="https://www.uscis.gov/tools/reports-and-studies/immigration-and-citizenship-data" target="_blank" rel="noopener noreferrer" class="underline hover:text-neutral-900">USCIS Reports and Studies</a>.
      </p>
    </div>
  </div>
</Layout>
