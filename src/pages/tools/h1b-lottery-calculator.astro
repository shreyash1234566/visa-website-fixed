---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';

const faqs = [
  { q: "What is the wage-weighted H1B lottery?", a: "Under the DHS proposed rule for FY2027, H1B registrations are assigned a 'weight' based on the prevailing wage level offered. Level IV (highest wages) registrations count 8× more than Level I registrations in the selection pool." },
  { q: "When does the FY2027 H1B registration open?", a: "H1B cap registration for FY2027 (starting October 1, 2026) typically opens in early March and runs for about 2 weeks. USCIS announces exact dates in February." },
  { q: "Does the rule change my $250 registration fee?", a: "No. The $250 per-beneficiary registration fee applies regardless of wage level. The fee is nonrefundable even if not selected." },
  { q: "What if the wage-weighted rule is overturned?", a: "If overturned, the lottery would revert to a pure random draw (FY2026 model) where all registrations have equal probability." },
  { q: "Can I have multiple registrations?", a: "Each beneficiary (worker) can only have one registration per employer. Multiple employers can register the same beneficiary, but USCIS selects the beneficiary — not duplicate registrations." },
  { q: "Does a Master's degree improve my odds?", a: "Yes. The Master's cap provides an additional 20,000 slots. Those who are not selected in the regular cap are put into a second lottery for the Master's cap, effectively giving them two chances." },
  { q: "What happens if I'm not selected?", a: "If you are not selected, your status will remain 'Submitted' in the USCIS portal. Sometimes USCIS runs a second or third lottery later in the year if the initial cap is not met." },
  { q: "Can my employer artificially inflate my wage level?", a: "No. The wage level must accurately reflect the job duties, requirements, and location on the Labor Condition Application (LCA). Falsifying wage levels is fraud." },
  { q: "Is the wage-weighted lottery finalized?", a: "As of mid-2026, it is a proposed rule by DHS. Always check the latest USCIS announcements before the March registration period." },
  { q: "How do I know what my wage level is?", a: "Your wage level is determined by the Department of Labor's OES prevailing wage data for your specific occupation and geographic area. Your employer or attorney will determine this when filing the LCA." }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};
---

<Layout
  title="H1B Lottery Odds Calculator FY2027 — Wage-Weighted Selection"
  description="Calculate your H1B lottery selection odds for FY2027 under the new DHS wage-level-weighted registration rule. Enter your wage level and see your chances."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Tools', href: '/tools' }, { label: 'H1B Lottery Calculator' }]} />

    <div class="mt-8 mb-6">
      <span class="inline-block bg-red-100 text-red-700 text-xs font-bold uppercase px-2 py-1 rounded mb-3">Hot — FY2027</span>
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">H-1B Lottery Odds Calculator</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">Under the DHS wage-weighted lottery rule, registrations offering higher wages get priority. Calculate your estimated selection odds for FY2027.</p>
    </div>

    <!-- Calculator Card -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm p-8 mb-8">
      <h2 class="text-lg font-bold text-neutral-900 mb-6">Enter Your Details</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Wage Level (DOL Prevailing Wage)</label>
          <select id="wageLevel" class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900 focus:border-neutral-900 bg-white">
            <option value="1">Level I — Entry Level (&lt; 17th percentile)</option>
            <option value="2" selected>Level II — Qualified (&lt; 34th percentile)</option>
            <option value="3">Level III — Experienced (&lt; 50th percentile)</option>
            <option value="4">Level IV — Fully Competent (≥ 50th percentile)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Cap Type</label>
          <select id="capType" class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900 focus:border-neutral-900 bg-white">
            <option value="regular">Regular Cap (65,000)</option>
            <option value="masters">U.S. Masters Cap (+20,000)</option>
          </select>
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-semibold text-neutral-700 mb-2">Fiscal Year</label>
        <div class="flex gap-3">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="fy" value="fy2027" checked class="text-neutral-900"> <span class="text-sm">FY2027 (wage-weighted — proposed)</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="fy" value="fy2026" class="text-neutral-900"> <span class="text-sm">FY2026 (random — historical)</span>
          </label>
        </div>
      </div>

      <button id="calcBtn" class="w-full md:w-auto px-8 py-3 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-700 transition-colors">
        Calculate My Odds
      </button>
    </div>

    <!-- Results Card -->
    <div id="results" class="hidden bg-white border border-emerald-200 rounded-2xl shadow-sm p-8 mb-8">
      <h2 class="text-lg font-bold text-neutral-900 mb-4">Your Estimated Lottery Odds</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="text-center p-5 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="selectionChance" class="text-4xl font-extrabold text-neutral-900 mb-1">—</div>
          <div class="text-sm text-neutral-500">Selection Probability</div>
        </div>
        <div class="text-center p-5 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="wageMultiplier" class="text-4xl font-extrabold text-neutral-900 mb-1">—</div>
          <div class="text-sm text-neutral-500">Wage Level Multiplier</div>
        </div>
        <div class="text-center p-5 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="totalRegistrations" class="text-4xl font-extrabold text-neutral-900 mb-1">~780K</div>
          <div class="text-sm text-neutral-500">Est. Total Registrations FY2027</div>
        </div>
      </div>
      <div id="resultSummary" class="text-sm text-neutral-600 p-4 bg-amber-50 border border-amber-200 rounded-xl"></div>
    </div>

    <!-- Wage Level Distribution Table -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-neutral-100">
        <h2 class="text-base font-bold text-neutral-900">FY2027 Wage-Weighted Selection Model</h2>
        <p class="text-xs text-neutral-400 mt-1">Based on DHS December 2025 proposed rule. Final rule pending.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100">
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Wage Level</th>
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Multiplier</th>
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Relative Odds vs Level I</th>
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Est. % of Registrations</th>
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Est. Selection Rate</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            <tr class="hover:bg-neutral-50"><td class="px-6 py-3 font-medium">Level I (Entry)</td><td class="px-6 py-3 text-neutral-500">1×</td><td class="px-6 py-3 text-neutral-500">Baseline</td><td class="px-6 py-3 text-neutral-500">~35%</td><td class="px-6 py-3 text-red-600 font-semibold">~4–7%</td></tr>
            <tr class="hover:bg-neutral-50"><td class="px-6 py-3 font-medium">Level II (Qualified)</td><td class="px-6 py-3 text-neutral-500">2×</td><td class="px-6 py-3 text-neutral-500">2× better</td><td class="px-6 py-3 text-neutral-500">~40%</td><td class="px-6 py-3 text-amber-600 font-semibold">~8–14%</td></tr>
            <tr class="hover:bg-neutral-50"><td class="px-6 py-3 font-medium">Level III (Experienced)</td><td class="px-6 py-3 text-neutral-500">4×</td><td class="px-6 py-3 text-neutral-500">4× better</td><td class="px-6 py-3 text-neutral-500">~18%</td><td class="px-6 py-3 text-emerald-600 font-semibold">~16–28%</td></tr>
            <tr class="hover:bg-neutral-50"><td class="px-6 py-3 font-medium">Level IV (Fully Competent)</td><td class="px-6 py-3 text-neutral-500">8×</td><td class="px-6 py-3 text-neutral-500">8× better</td><td class="px-6 py-3 text-neutral-500">~7%</td><td class="px-6 py-3 text-emerald-600 font-bold">~32–55%</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <FAQAccordion faqs={faqs} title="H1B Lottery FAQs" />

    <!-- Disclaimer -->
    <p class="text-xs text-neutral-400 p-4 bg-neutral-50 rounded-xl border border-neutral-200">
      <strong>Disclaimer:</strong> These calculations are estimates based on the DHS December 2025 proposed wage-weighted H1B lottery rule and historical registration volumes. The final rule has not been published. Actual odds depend on total registrations, USCIS implementation, and other factors. This tool is for informational purposes only and does not constitute legal advice.
    </p>
  </div>
</Layout>

<script>
  const calcBtn = document.getElementById('calcBtn');
  const results = document.getElementById('results');

  // Model: DHS proposed wage-weighted H1B lottery
  // Multipliers: L1=1, L2=2, L3=4, L4=8
  // Cap: regular=65000, masters=85000
  // Est FY2027 registrations: ~780K (based on FY2026 trend)
  // Distribution: ~35% L1, ~40% L2, ~18% L3, ~7% L4

  const MULTIPLIERS = { '1': 1, '2': 2, '3': 4, '4': 8 };
  const DIST = { '1': 0.35, '2': 0.40, '3': 0.18, '4': 0.07 };
  const TOTAL_REGS = 780000;
  const CAP_REGULAR = 65000;
  const CAP_MASTERS = 20000;

  function calcOdds(wageLevel: string, capType: string, isFY2027: boolean) {
    const cap = capType === 'masters' ? (CAP_REGULAR + CAP_MASTERS) : CAP_REGULAR;
    const multiplier = MULTIPLIERS[wageLevel as keyof typeof MULTIPLIERS];
    
    if (!isFY2027) {
      // Simple random — everyone equal
      const rate = Math.min(cap / TOTAL_REGS, 1.0);
      return { rate, multiplier: 1, label: 'Equal random draw' };
    }

    // Weighted draw: weighted slots available
    // Total weighted pool = sum(regs_per_level * multiplier_per_level)
    const weightedPool = Object.entries(DIST).reduce((sum, [lvl, pct]) => {
      return sum + (TOTAL_REGS * pct * MULTIPLIERS[lvl as keyof typeof MULTIPLIERS]);
    }, 0);

    // My weighted slots
    const myWeight = multiplier;
    // Effective probability = (cap / weightedPool) * myWeight
    const rate = Math.min((cap / weightedPool) * myWeight, 1.0);
    return { rate, multiplier, label: `Level ${wageLevel} wage multiplier` };
  }

  calcBtn?.addEventListener('click', () => {
    const wageLevel = (document.getElementById('wageLevel') as HTMLSelectElement).value;
    const capType = (document.getElementById('capType') as HTMLSelectElement).value;
    const fy = (document.querySelector('input[name="fy"]:checked') as HTMLInputElement)?.value;
    const isFY2027 = fy === 'fy2027';

    const { rate, multiplier } = calcOdds(wageLevel, capType, isFY2027);
    const pct = (rate * 100).toFixed(1);

    document.getElementById('selectionChance')!.textContent = `${pct}%`;
    document.getElementById('wageMultiplier')!.textContent = isFY2027 ? `${multiplier}×` : '1× (random)';

    const lvlLabels: Record<string, string> = { '1': 'Entry (Level I)', '2': 'Qualified (Level II)', '3': 'Experienced (Level III)', '4': 'Fully Competent (Level IV)' };
    const summaryEl = document.getElementById('resultSummary')!;
    
    if (isFY2027) {
      summaryEl.innerHTML = `<strong>FY2027 Estimate:</strong> At wage ${lvlLabels[wageLevel]}, your registration carries a <strong>${multiplier}× weight multiplier</strong>. 
      Estimated selection probability: <strong>${pct}%</strong>. 
      ${Number(pct) > 20 ? '✅ Strong odds — high wage level puts you in the top selection tier.' : Number(pct) > 10 ? '⚠️ Moderate odds — consider if employer can justify higher wage level to boost chances.' : '❌ Low odds — wage-weighted rule heavily penalizes Level I/II registrations.'}`;
    } else {
      summaryEl.innerHTML = `<strong>FY2026 Historical (Random Draw):</strong> All registrations had equal probability. Estimated selection rate: <strong>${pct}%</strong>. Under the proposed FY2027 wage-weighted rule, switching to Level IV would give approximately <strong>${(calcOdds('4', capType, true).rate * 100).toFixed(1)}%</strong> odds.`;
    }

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
