---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us" description="Get in touch with the US Visa Tracker team.">
	<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
		<h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-8">Contact Us</h1>
		<div class="prose prose-neutral max-w-none text-neutral-600 bg-white p-8 rounded-2xl border border-neutral-200 shadow-sm">
			<p class="text-lg mb-6">We're always looking to improve our platform. Whether you've found a bug, want to suggest a new feature, or have a question about our data sources, we'd love to hear from you.</p>
			
			<h2 class="text-2xl font-bold tracking-tight text-neutral-900 mb-4">Email Us</h2>
			<p>For all general inquiries, support requests, and business queries, please reach out to us at:</p>
			<p class="text-xl font-medium text-neutral-900 mb-8"><a href="mailto:contact@usvisatracker.example.com" class="text-neutral-900 hover:text-neutral-600">contact@usvisatracker.example.com</a></p>

			<div class="bg-neutral-50 border-l-4 border-neutral-800 p-5 mt-8">
				<h3 class="text-neutral-900 font-bold mb-2">Important Notice</h3>
				<p class="text-neutral-600 m-0">We are not immigration attorneys. We cannot provide legal advice regarding your specific case, evaluate your chances of approval, or contact USCIS on your behalf. For legal assistance, please consult a qualified immigration lawyer.</p>
			</div>
		</div>
	</div>
</Layout>
