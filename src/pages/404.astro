---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found" description="The page you are looking for could not be found.">
	<div class="min-h-[60vh] flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8 text-center">
		<h1 class="text-9xl font-extrabold text-blue-700 mb-4">404</h1>
		<h2 class="text-3xl font-bold text-gray-900 mb-4">Page Not Found</h2>
		<p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
			Sorry, we couldn't find the page you're looking for. It might have been moved, deleted, or the URL might be incorrect.
		</p>
		<a href="/" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 transition-colors">
			Return Home
		</a>
	</div>
</Layout>
