---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import WaitTimeTrendChart from '../../components/WaitTimeTrendChart.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';

export async function getStaticPaths() {
  const countries = await getCollection('appointmentWaitTimes');
  return countries.map((c) => ({
    params: { country: c.data.slug },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const c = entry.data;

function badge(days: number | null) {
  if (days === null) return { cls: 'bg-neutral-100 text-neutral-700', label: 'N/A' };
  if (days < 60) return { cls: 'bg-green-100 text-green-800', label: 'Fast' };
  if (days < 180) return { cls: 'bg-amber-100 text-amber-800', label: 'Moderate' };
  return { cls: 'bg-red-100 text-red-800', label: 'High demand' };
}

const faqs = [
  {
    q: `How accurate are these wait times for ${c.country}?`,
    a: 'Wait times reflect a snapshot of the next available standard visitor visa appointment slot at each post. They can shift by days or weeks based on staffing changes, local holidays, and demand spikes, so always confirm the live figure on the embassy or consulate booking site before finalizing travel plans.',
  },
  {
    q: 'What is an emergency or expedited appointment?',
    a: 'Most posts offer an expedite request process for urgent travel needs (medical emergencies, funeral travel, business-critical trips). Approval criteria and availability vary by post and are decided case by case.',
  },
  {
    q: 'Does a long wait time affect my visa approval chances?',
    a: 'No — wait time only reflects appointment scheduling availability at that post, not the likelihood of visa approval. Approval depends on your individual application and consular interview.',
  },
];
---

<Layout title={`US Visa Appointment Wait Times — ${c.country} [2026]`} description={`Current US visitor visa interview appointment wait times for ${c.country}, by consulate, with 12-month trend charts.`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Appointment Wait Times', href: '/us-visa-appointment-wait-times' },
      { label: c.country },
    ]} />

    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900">{c.country}</h1>
    </div>
    <p class="text-lg text-neutral-500 mb-10">Visitor visa (B1/B2) appointment wait times by consulate. Updated {new Date(c.lastUpdated).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}.</p>

    <div class="space-y-8">
      {c.consulates.map((co) => {
        const b = badge(co.waitTimeB1B2);
        return (
          <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between bg-neutral-50/60">
              <h2 class="font-bold text-neutral-900">{co.name}</h2>
              <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${b.cls}`}>{b.label}</span>
            </div>
            <div class="grid grid-cols-3 divide-x divide-neutral-100 border-b border-neutral-100">
              <div class="p-5 text-center">
                <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Visitor (B1/B2)</p>
                <p class="text-2xl font-black text-neutral-900">{co.waitTimeB1B2 ?? '—'}<span class="text-sm font-medium text-neutral-500"> days</span></p>
              </div>
              <div class="p-5 text-center">
                <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Student (F/M/J)</p>
                <p class="text-2xl font-black text-neutral-900">{co.waitTimeStudent ?? '—'}<span class="text-sm font-medium text-neutral-500"> days</span></p>
              </div>
              <div class="p-5 text-center">
                <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Other</p>
                <p class="text-2xl font-black text-neutral-900">{co.waitTimeOther ?? '—'}<span class="text-sm font-medium text-neutral-500"> days</span></p>
              </div>
            </div>
            {co.notes && (
              <div class="px-6 py-3 bg-amber-50 border-b border-amber-100 text-xs text-amber-900">{co.notes}</div>
            )}
            <div class="p-6">
              <WaitTimeTrendChart history={co.history} title={`${co.name} — 12-month trend`} />
            </div>
          </div>
        );
      })}
    </div>

    <FAQAccordion faqs={faqs} title={`${c.country} Visa Appointment FAQs`} />
  </div>
</Layout>
